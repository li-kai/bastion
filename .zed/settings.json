{
  "languages": {
    "Rust": {
      "formatter": "language_server",
      "format_on_save": "on"
    }
  },

  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "cargo": {
          "features": "all"
        },
        "check": {
          "command": "clippy"
        },
        "imports": {
          "granularity": {
            "enforce": true,
            "group": "item"
          },
          "group": {
            "enable": true
          }
        }
      }
    }
  }
}
