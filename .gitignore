# Generated by Cargo
# will have compiled files and executables
debug/
target/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Environment
/.direnv

# Claude Code - keep shared settings, hooks, plugins, skills
/.claude/*
!/.claude/hooks/
!/.claude/plugins/
!/.claude/settings.json
!/.claude/skills/

# OpenAI Codex CLI - keep shared config and instructions
/.codex/*
!/.codex/config.toml
!/.codex/AGENTS.md

# Cursor - keep shared rules
/.cursor/*
!/.cursor/rules/

# GitHub Copilot - only ignore local settings
.github/copilot/settings.local.json
